{% extends 'base.html.twig' %}

{% block title %}VictoriousPuppy index{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>VictoriousPuppy index</h1>
        <a href="{{ path('app_victorious_puppy_new') }}" class="btn btn-primary">+ Create new</a>
    </div>

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Value</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        {% for victorious_puppy in victorious_puppies %}
            <tr>
                <td>{{ victorious_puppy.id }}</td>
                <td>{{ victorious_puppy.name }}</td>
                <td>{{ victorious_puppy.value }}</td>
                <td>
                    <a href="{{ path('app_victorious_puppy_show', {'id': victorious_puppy.id}) }}" class="btn btn-sm btn-info">show</a>
                    <a href="{{ path('app_victorious_puppy_edit', {'id': victorious_puppy.id}) }}" class="btn btn-sm btn-secondary">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4" class="text-center text-muted">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
