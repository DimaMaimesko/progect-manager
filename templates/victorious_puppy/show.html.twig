
{% extends 'base.html.twig' %}

{% block title %}VictoriousPuppy{% endblock %}

{% block body %}
    <div class="card" style="max-width: 500px;">
        <div class="card-header">
            <h1 class="h4 mb-0">VictoriousPuppy</h1>
        </div>
        <div class="card-body">
            <table class="table table-borderless mb-0">
                <tbody>
                <tr>
                    <th>Id</th>
                    <td>{{ victorious_puppy.id }}</td>
                </tr>
                <tr>
                    <th>Name</th>
                    <td>{{ victorious_puppy.name }}</td>
                </tr>
                <tr>
                    <th>Value</th>
                    <td>{{ victorious_puppy.value }}</td>
                </tr>
                </tbody>
            </table>
        </div>
        <div class="card-footer d-flex gap-2">
            <a href="{{ path('app_victorious_puppy_index') }}" class="btn btn-secondary">back to list</a>
            <a href="{{ path('app_victorious_puppy_edit', {'id': victorious_puppy.id}) }}" class="btn btn-primary">edit</a>
            {{ include('victorious_puppy/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
